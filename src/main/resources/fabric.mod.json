	"authors": [
		"Alex Alabai"
	],
	"contact": {
		"homepage": "https://fabricmc.net/"
	},
	"license": "CC0-1.0",
	"icon": "assets/how-hungry/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": ["ru.alexalabai.howhungry.HowHungry"],
		"client": ["ru.alexalabai.howhungry.HowHungryClient"],
		"modmenu": ["ru.alexalabai.howhungry.config.ModMenuIntegration"]
	},
	"mixins": [
		"how-hungry.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.17.3",
		"minecraft": ">=1.20",
		"java": ">=17",
		"fabric-api": "*"
	}
